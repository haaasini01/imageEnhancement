<div class="container">
  <div class="header">
    <h2>Image Enhancement</h2>
    <p>Upload an image and apply beautiful filters powered by advanced algorithms.</p>
  </div>

  <%= form_with url: "/enhance", method: :post, multipart: true, data: { turbo: false } do |f| %>
    <div class="form-group">
      <label for="image_upload">Upload Image</label>
      <%= f.file_field :image, class: "form-control", id: "image_upload", required: true, accept: "image/*" %>
    </div>
    
    <div class="form-group">
      <label for="filter_select">Select Filter</label>
      <%= f.select :filter, options_for_select([
        ['Blur', 'blur'],
        ['Sharpen', 'sharpen'],
        ['Edge Detection', 'edge_detection'],
        ['Histogram Equalization', 'histogram_equalization'],
        ['Brightness', 'brightness'],
        ['Contrast', 'contrast'],
        ['Grayscale', 'grayscale'],
        ['--- Artistic Filters ---', nil, { disabled: true }],
        ['Cartoon Effect', 'cartoon_effect'],
        ['Pencil Sketch', 'pencil_sketch'],
        ['Oil Painting', 'oil_painting'],
        ['Watercolor', 'watercolor'],
        ['Vintage / Sepia Tone', 'vintage_sepia']
      ]), {}, { class: "form-control", id: "filter_select" } %>
    </div>
    
    <div class="form-group">
      <label for="value_input">Parameters (optional)</label>
      <%= f.text_field :value, class: "form-control", id: "value_input", placeholder: "Brightness: 0-200, Contrast: 0.5-3.0" %>
      <%= f.text_field :radius, class: "form-control", id: "radius_input", placeholder: "Oil Painting radius (1-10, default: 4)", style: "margin-top: 0.5rem;" %>
      <%= f.text_field :intensity, class: "form-control", id: "intensity_input", placeholder: "Watercolor intensity (1-10, default: 3)", style: "margin-top: 0.5rem;" %>
    </div>
    
    <div class="actions" style="margin-top: 2rem;">
      <%= f.submit "Enhance Image", class: "btn-primary" %>
    </div>
  <% end %>
</div>