<h2>Image Enhancement Tool</h2>

<%= form_with url: "/enhance", method: :post, multipart: true, data: { turbo: false } do |f| %>

<label>Upload Image</label>
<%= f.file_field :image %>

<br><br>

<label>Select Filter</label>
<%= f.select :filter, options_for_select([
  ['Blur', 'blur'],
  ['Sharpen', 'sharpen'],
  ['Edge Detection', 'edge_detection'],
  ['Histogram Equalization', 'histogram_equalization'],
  ['Brightness', 'brightness'],
  ['Contrast', 'contrast']
]) %>

<br><br>

<label>Value (for brightness/contrast)</label>
<%= f.text_field :value %>

<br><br>

<%= f.submit "Enhance Image" %>

<% end %>